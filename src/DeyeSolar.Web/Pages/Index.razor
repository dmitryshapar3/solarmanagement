@page "/"
@inject DeviceStatusSnapshot DeviceSnapshot
@inject DeyeSolar.Domain.Interfaces.ISocketController SocketController
@inject Microsoft.Extensions.Options.IOptionsMonitor<DeyeSolar.Domain.Options.SocketBackendOptions> SocketBackendOpts
@inject DeyeSolar.Web.Data.AppSettingsService SettingsService
@using DeyeSolar.Web.Shared
@implements IDisposable

<PageTitle>Dashboard - DeyeSolar</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info" Dense="true">
            Bridge-only mode is active. This dashboard reflects the latest state reported by the home bridge.
        </MudAlert>
    </MudItem>

    <MudItem xs="12">
        <MudText Typo="Typo.caption" Class="mb-2">
            Last device update:
            @if (DeviceSnapshot.LastUpdated.HasValue)
            {
                <text>@TimeHelper.ToUserTime(DeviceSnapshot.LastUpdated.Value.UtcDateTime, _tz).ToString("HH:mm:ss")</text>
            }
            else
            {
                <text>waiting for bridge heartbeat</text>
            }
        </MudText>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Configured Bridge</MudText>
            <MudText Typo="Typo.h5">@(!string.IsNullOrWhiteSpace(_bridgeId) ? _bridgeId : "not set")</MudText>
            <MudText Typo="Typo.caption">Use Settings to change the active bridge.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Color="Color.Info">Known Devices</MudText>
            <MudText Typo="Typo.h4">@(_devices?.Count ?? 0)</MudText>
            <MudText Typo="Typo.caption">Currently reported by the bridge.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Color="Color.Success">Online</MudText>
            <MudText Typo="Typo.h4">@(_devices?.Count(d => d.Online) ?? 0)</MudText>
            <MudText Typo="Typo.caption">Bridge devices responding.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Color="Color.Warning">Active Load</MudText>
            <MudText Typo="Typo.h4">@((_devices?.Where(d => d.CurrentPowerW.HasValue).Sum(d => d.CurrentPowerW ?? 0) ?? 0)) W</MudText>
            <MudText Typo="Typo.caption">Sum of reported bridge device power.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText>
            <MudText Typo="Typo.caption" Class="mb-2">
                Manual override for the default bridge device configured in Settings.
            </MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           Disabled="@string.IsNullOrWhiteSpace(_defaultDeviceId)"
                           OnClick="@(() => ManualToggle(true))">
                    Socket ON
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           Disabled="@string.IsNullOrWhiteSpace(_defaultDeviceId)"
                           OnClick="@(() => ManualToggle(false))">
                    Socket OFF
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.caption" Class="mt-2">
                Default device:
                @if (string.IsNullOrWhiteSpace(_defaultDeviceId))
                {
                    <text>not selected</text>
                }
                else
                {
                    <code>@_defaultDeviceId</code>
                }
            </MudText>
            @if (!string.IsNullOrEmpty(_actionMessage))
            {
                <MudAlert Severity="@_actionSeverity" Class="mt-2">@_actionMessage</MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Smart Sockets</MudText>
            @if (_devices == null)
            {
                <MudAlert Severity="Severity.Info">Waiting for first bridge device update...</MudAlert>
            }
            else if (_devices.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No bridge devices found. Configure and scan the bridge in Settings.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>State</th>
                            <th>Power</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dev in _devices)
                        {
                            <tr>
                                <td>@dev.Name</td>
                                <td>
                                    @if (!dev.Online)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">offline</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(dev.IsOn ? Color.Success : Color.Default)">
                                            @(dev.IsOn ? "ON" : "OFF")
                                        </MudChip>
                                    }
                                </td>
                                <td>@(dev.CurrentPowerW.HasValue ? $"{dev.CurrentPowerW.Value} W" : "-")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IReadOnlyList<DevicePowerInfo>? _devices;
    private string? _actionMessage;
    private Severity _actionSeverity;
    private string? _tz;
    private string _bridgeId = string.Empty;
    private string _defaultDeviceId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var display = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.DisplayOptions>("Display");
        var socketBackend = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.SocketBackendOptions>("SocketBackend");
        _tz = display.TimeZoneId;
        _bridgeId = socketBackend.BridgeId;
        _defaultDeviceId = socketBackend.DefaultDeviceId;
        _devices = DeviceSnapshot.Current;
        DeviceSnapshot.OnDataUpdated += OnDeviceSnapshotUpdated;
    }

    private async void OnDeviceSnapshotUpdated()
    {
        _devices = DeviceSnapshot.Current;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ManualToggle(bool turnOn)
    {
        try
        {
            var entityId = SocketBackendOpts.CurrentValue.DefaultDeviceId;
            if (turnOn)
                await SocketController.TurnOnAsync(entityId, CancellationToken.None);
            else
                await SocketController.TurnOffAsync(entityId, CancellationToken.None);

            _defaultDeviceId = entityId;
            _actionMessage = turnOn ? "Socket turned ON" : "Socket turned OFF";
            _actionSeverity = Severity.Success;
        }
        catch (Exception ex)
        {
            _actionMessage = $"Error: {ex.Message}";
            _actionSeverity = Severity.Error;
        }
    }

    public void Dispose()
    {
        DeviceSnapshot.OnDataUpdated -= OnDeviceSnapshotUpdated;
    }
}
