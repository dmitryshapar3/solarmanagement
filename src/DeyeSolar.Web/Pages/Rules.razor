@page "/rules"
@inject DeyeSolar.Domain.Interfaces.IRuleRepository RuleRepo
@inject DeyeSolar.Web.Data.AppSettingsService SettingsService
@inject NavigationManager Nav
@using DeyeSolar.Web.Shared

<PageTitle>Rules - DeyeSolar</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Trigger Rules</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/rules/edit"
           StartIcon="@Icons.Material.Filled.Add" Class="mb-4">
    Add Rule
</MudButton>

@if (_rules == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_rules.Count == 0)
{
    <MudAlert Severity="Severity.Info">No rules configured. Create one to get started.</MudAlert>
}
else
{
    <MudTable Items="_rules" Hover="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Device</MudTh>
            <MudTh>Turn ON</MudTh>
            <MudTh>Turn OFF</MudTh>
            <MudTh>Interval</MudTh>
            <MudTh>State</MudTh>
            <MudTh>Changed</MudTh>
            <MudTh>Enabled</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                @if (string.IsNullOrEmpty(context.EntityId))
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Not set</MudChip>
                }
                else
                {
                    <MudText Typo="Typo.body2">@context.EntityId[..Math.Min(context.EntityId.Length, 12)]...</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.SocTurnOnThreshold.HasValue)
                {
                    <span>SOC >= @context.SocTurnOnThreshold%</span>
                }
                else
                {
                    <span>-</span>
                }
            </MudTd>
            <MudTd>
                @if (context.MaxConsumptionWh.HasValue)
                {
                    <span>> @(context.MaxConsumptionWh)Wh in @(context.MonitoringWindowMinutes)min</span>
                }
                else
                {
                    <span>-</span>
                }
            </MudTd>
            <MudTd>@(context.IntervalSeconds)s</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.CurrentState ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.CurrentState ? "ON" : "OFF")
                </MudChip>
            </MudTd>
            <MudTd>
                @if (context.CurrentStateChangedAt.HasValue)
                {
                    <MudText Typo="Typo.body2">
                        @TimeHelper.ToUserTime(context.CurrentStateChangedAt.Value, _tz).ToString("MM/dd HH:mm:ss")
                    </MudText>
                }
                else
                {
                    <span>-</span>
                }
            </MudTd>
            <MudTd>
                <MudSwitch T="bool" Value="context.Enabled" ValueChanged="@(v => ToggleEnabled(context, v))"
                           Color="Color.Primary" />
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/rules/edit/{context.Id}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteRule(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<TriggerRule>? _rules;
    private string? _tz;

    protected override async Task OnInitializedAsync()
    {
        var display = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.DisplayOptions>("Display");
        _tz = display.TimeZoneId;
        _rules = await RuleRepo.GetAllAsync(CancellationToken.None);
    }

    private async Task ToggleEnabled(TriggerRule rule, bool enabled)
    {
        rule.Enabled = enabled;
        await RuleRepo.UpdateAsync(rule, CancellationToken.None);
    }

    private async Task DeleteRule(int id)
    {
        await RuleRepo.DeleteAsync(id, CancellationToken.None);
        _rules = await RuleRepo.GetAllAsync(CancellationToken.None);
    }
}
