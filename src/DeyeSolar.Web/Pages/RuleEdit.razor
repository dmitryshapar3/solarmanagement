@page "/rules/edit"
@page "/rules/edit/{Id:int}"
@inject DeyeSolar.Domain.Interfaces.IRuleRepository RuleRepo
@inject DeyeSolar.Infrastructure.Tuya.TuyaCloudClient TuyaClient
@inject DeyeSolar.Web.Data.AppSettingsService SettingsService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "New Rule" : "Edit Rule") - DeyeSolar</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">@(_isNew ? "Create Rule" : "Edit Rule")</MudText>

<MudPaper Class="pa-4" MaxWidth="600px" Elevation="2">
    <MudForm @ref="_form">
        <MudTextField @bind-Value="_rule.Name" Label="Rule Name" Required="true"
                      RequiredError="Name is required" />

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Target Device</MudText>
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2">
            <MudSelect T="string" @bind-Value="_rule.EntityId" Label="Device" Required="true"
                       RequiredError="Select a device" Variant="Variant.Outlined" Style="flex:1">
                @if (_devices != null)
                {
                    @foreach (var d in _devices)
                    {
                        <MudSelectItem T="string" Value="@d.Id">@d.Name (@d.Category) @(d.Online ? "" : "- offline")</MudSelectItem>
                    }
                }
                @if (!string.IsNullOrEmpty(_rule.EntityId) && (_devices == null || !_devices.Any(d => d.Id == _rule.EntityId)))
                {
                    <MudSelectItem T="string" Value="@_rule.EntityId">@_rule.EntityId</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadDevices"
                       Disabled="_loadingDevices" Size="Size.Medium">
                @if (_loadingDevices) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Load
            </MudButton>
        </MudStack>
        @if (!string.IsNullOrEmpty(_loadError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_loadError</MudAlert>
        }
        else if (string.IsNullOrEmpty(_rule.EntityId))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                A device must be selected before the rule can be enabled.
            </MudAlert>
        }

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Turn ON Condition</MudText>
        <MudNumericField @bind-Value="_rule.SocTurnOnThreshold" Label="Battery SOC at or above (%)"
                         Min="0" Max="100"
                         HelperText="Turn on when battery charge reaches this level" />
        <MudCheckBox @bind-Value="_rule.RequireBatteryCharging" Label="Require battery to be charging"
                     Color="Color.Primary" Class="mt-2" />
        <MudText Typo="Typo.caption" Class="ml-8" Style="display:block;">
            Only turn on while the battery is actively charging (solar surplus present).
        </MudText>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Turn OFF Conditions</MudText>
        <MudNumericField @bind-Value="_rule.MaxDrainWh" Label="Max net battery drain (Wh)"
                         Min="0" Max="100000"
                         HelperText="Turn off when net battery discharge over the window reaches this value. Battery charging cancels prior drain, so short cloud transients are absorbed." />
        <MudNumericField @bind-Value="_rule.DrainWindowMinutes" Label="Drain window (min)"
                         Min="1" Max="240" Class="mt-2"
                         HelperText="Time window over which to accumulate net battery drain" />
        <MudNumericField @bind-Value="_rule.SocFloor" Label="SOC safety floor (%)"
                         Min="0" Max="100" Class="mt-2"
                         HelperText="Hard cutoff: turn off immediately if battery drops to this level (overrides min-on time)" />

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Anti-flapping</MudText>
        <MudGrid>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_rule.MinOnMinutes" Label="Min ON time (min)"
                                 Min="0" Max="240"
                                 HelperText="Keep ON at least this long after turning on (ignored by SOC floor)" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_rule.CooldownMinutes" Label="Cooldown after OFF (min)"
                                 Min="0" Max="240"
                                 HelperText="Keep OFF at least this long before re-evaluating turn-on" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Evaluation</MudText>
        <MudNumericField @bind-Value="_rule.IntervalSeconds" Label="Evaluate every (sec)"
                         Min="10" Max="3600"
                         HelperText="How often this rule runs" />

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Time Window (optional)</MudText>
        <MudGrid>
            <MudItem xs="6">
                <MudTimePicker @bind-Time="_activeFrom" Label="Active From" />
            </MudItem>
            <MudItem xs="6">
                <MudTimePicker @bind-Time="_activeTo" Label="Active To" />
            </MudItem>
        </MudGrid>

        <MudSwitch @bind-Value="_rule.Enabled" Label="Enabled" Color="Color.Primary" Class="mt-3"
                   Disabled="@string.IsNullOrEmpty(_rule.EntityId)" />

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
            <MudButton Variant="Variant.Outlined" Href="/rules">Cancel</MudButton>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter] public int? Id { get; set; }

    private TriggerRule _rule = new()
    {
        Enabled = false,
        SocTurnOnThreshold = 80,
        SocFloor = 55,
        MaxDrainWh = 200,
        DrainWindowMinutes = 15,
        MinOnMinutes = 10,
        CooldownMinutes = 15,
        IntervalSeconds = 30
    };
    private bool _isNew => Id == null;
    private MudForm? _form;
    private TimeSpan? _activeFrom;
    private TimeSpan? _activeTo;
    private List<DeyeSolar.Infrastructure.Tuya.TuyaDevice>? _devices;
    private bool _loadingDevices;
    private string? _loadError;
    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await RuleRepo.GetByIdAsync(Id.Value, CancellationToken.None);
            if (existing != null)
            {
                _rule = existing;
                _activeFrom = _rule.ActiveFrom?.ToTimeSpan();
                _activeTo = _rule.ActiveTo?.ToTimeSpan();
            }
        }

        await LoadDevices();
    }

    private async Task LoadDevices()
    {
        _loadingDevices = true;
        _loadError = null;
        try
        {
            _devices = await TuyaClient.GetDevicesAsync(CancellationToken.None);
            if (_devices.Count == 0)
                _loadError = "No devices found. Check Tuya settings.";
        }
        catch (Exception ex)
        {
            _devices = [];
            _loadError = $"Failed to load devices: {ex.Message}";
        }
        finally
        {
            _loadingDevices = false;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrEmpty(_rule.EntityId))
            _rule.Enabled = false;

        if (_form != null)
        {
            await _form.Validate();
            if (!_form.IsValid) return;
        }

        _rule.ActiveFrom = _activeFrom.HasValue ? TimeOnly.FromTimeSpan(_activeFrom.Value) : null;
        _rule.ActiveTo = _activeTo.HasValue ? TimeOnly.FromTimeSpan(_activeTo.Value) : null;

        if (_isNew)
            await RuleRepo.CreateAsync(_rule, CancellationToken.None);
        else
            await RuleRepo.UpdateAsync(_rule, CancellationToken.None);

        Nav.NavigateTo("/rules");
    }
}
