@page "/devices"
@inject DeyeSolar.Web.Data.AppSettingsService SettingsService

<PageTitle>Devices - DeyeSolar</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Socket Control</MudText>

<MudPaper Class="pa-4" Elevation="2">
    @if (string.IsNullOrWhiteSpace(_deviceId))
    {
        <MudAlert Severity="Severity.Warning">
            No Tuya socket is selected yet. Configure the cloud credentials and pick a device in Settings.
        </MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Cloud-control mode is active. The app sends ON/OFF commands to Tuya Cloud but does not poll live socket power or status.
        </MudAlert>

        <MudSimpleTable Dense="true">
            <thead>
                <tr>
                    <th>Setting</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Region</td><td>@_baseUrl</td></tr>
                <tr><td>Device ID</td><td><code>@_deviceId</code></td></tr>
            </tbody>
        </MudSimpleTable>
    }
</MudPaper>

@code {
    private string? _deviceId;
    private string? _baseUrl;

    protected override async Task OnInitializedAsync()
    {
        var tuya = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.TuyaOptions>("Tuya");
        _deviceId = tuya.DeviceId;
        _baseUrl = tuya.BaseUrl;
    }
}
