@page "/settings"
@inject DeyeSolar.Web.Data.AppSettingsService SettingsService
@inject DeyeSolar.Infrastructure.DeyeCloud.DeyeCloudClient DeyeClient
@inject DeyeSolar.Infrastructure.Tuya.TuyaCloudClient TuyaClient
@inject ISnackbar Snackbar

<PageTitle>Settings - DeyeSolar</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudGrid>
    <!-- DeyeCloud -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Inverter (DeyeCloud)</MudText>
            <MudTextField @bind-Value="_deye.BaseUrl" Label="Base URL" />
            <MudTextField @bind-Value="_deye.AppId" Label="App ID" Class="mt-2" />
            <MudTextField @bind-Value="_deye.AppSecret" Label="App Secret" Class="mt-2" InputType="InputType.Password" />
            <MudTextField @bind-Value="_deye.Email" Label="Email" Class="mt-2" />
            <MudTextField @bind-Value="_deye.Password" Label="Password" Class="mt-2" InputType="InputType.Password" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDeye" Class="mt-3">
                Save
            </MudButton>

            <MudDivider Class="my-3" />

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="FetchStations"
                       Disabled="_loadingStations" FullWidth="true">
                @if (_loadingStations) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Fetch Stations & Devices
            </MudButton>

            @if (_stations?.Count > 0)
            {
                <MudSelect T="long" @bind-Value="_selectedStationId" Label="Station" Class="mt-2" Variant="Variant.Outlined" Dense="true">
                    @foreach (var s in _stations)
                    {
                        <MudSelectItem T="long" Value="s.Id">@s.Name @(s.Address != null ? $"({s.Address})" : "")</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="FetchDevices"
                           Disabled="_loadingDevices || _selectedStationId == 0" Class="mt-2" FullWidth="true">
                    @if (_loadingDevices) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Fetch Devices
                </MudButton>
            }

            @if (_devices?.Count > 0)
            {
                <MudStack Spacing="1" Class="mt-2">
                    @foreach (var d in _devices)
                    {
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined"
                                 OnClick="@(() => SelectDevice(d))" Style="cursor:pointer">
                            @d.DeviceType - SN: @d.SerialNumber
                        </MudChip>
                    }
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_deye.DeviceSn))
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    Active: Station @_deye.StationId, Device SN @_deye.DeviceSn
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <!-- Tuya Smart Socket -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Smart Socket (Tuya)</MudText>
            <MudSelect @bind-Value="_tuya.BaseUrl" Label="Region" Variant="Variant.Outlined">
                <MudSelectItem Value="@("https://openapi.tuyaeu.com")">Europe</MudSelectItem>
                <MudSelectItem Value="@("https://openapi.tuyaus.com")">Americas</MudSelectItem>
                <MudSelectItem Value="@("https://openapi.tuyacn.com")">China</MudSelectItem>
                <MudSelectItem Value="@("https://openapi.tuyain.com")">India</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_tuya.AccessId" Label="Access ID" Class="mt-2" />
            <MudTextField @bind-Value="_tuya.AccessSecret" Label="Access Secret" Class="mt-2" InputType="InputType.Password" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTuya" Class="mt-3">
                Save
            </MudButton>

            <MudDivider Class="my-3" />

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="FetchTuyaDevices"
                       Disabled="_loadingTuya" FullWidth="true">
                @if (_loadingTuya) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Fetch Devices from Tuya
            </MudButton>

            @if (_tuyaDevices?.Count > 0)
            {
                <MudStack Spacing="1" Class="mt-2">
                    @foreach (var d in _tuyaDevices)
                    {
                        <MudChip T="string" Color="@(d.Online ? Color.Success : Color.Default)"
                                 Variant="Variant.Outlined"
                                 OnClick="@(() => SelectTuyaDevice(d))" Style="cursor:pointer">
                            @d.Name (@d.Category) @(d.Online ? "" : "- offline")
                        </MudChip>
                    }
                </MudStack>
            }

            <MudTextField @bind-Value="_tuya.DeviceId" Label="Device ID" Class="mt-2" ReadOnly="true" />

            @if (!string.IsNullOrEmpty(_tuya.DeviceId))
            {
                <MudStack Row="true" Spacing="2" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="TestOn" Size="Size.Small">Test ON</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="TestOff" Size="Size.Small">Test OFF</MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudItem>

    <!-- Polling -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Polling</MudText>
            <MudNumericField @bind-Value="_polling.IntervalSeconds" Label="Interval (seconds)" Min="5" Max="300" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePolling" Class="mt-3">Save</MudButton>
        </MudPaper>
    </MudItem>

    <!-- Display -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Display</MudText>
            <MudAutocomplete T="string" @bind-Value="_display.TimeZoneId" Label="Timezone"
                             SearchFunc="SearchTimezones" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDisplay" Class="mt-3">Save</MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">@_errorMessage</MudAlert>
}

@inject IJSRuntime JS

@code {
    private DeyeSolar.Domain.Options.DeyeCloudOptions _deye = new();
    private DeyeSolar.Domain.Options.TuyaOptions _tuya = new();
    private DeyeSolar.Domain.Options.PollingOptions _polling = new();
    private DeyeSolar.Domain.Options.DisplayOptions _display = new();

    private List<DeyeSolar.Infrastructure.DeyeCloud.DeyeStation>? _stations;
    private List<DeyeSolar.Infrastructure.DeyeCloud.DeyeDevice>? _devices;
    private List<DeyeSolar.Infrastructure.Tuya.TuyaDevice>? _tuyaDevices;
    private long _selectedStationId;
    private bool _loadingStations, _loadingDevices, _loadingTuya;
    private string? _errorMessage;
    private static readonly string[] _allTimeZones = TimeZoneInfo.GetSystemTimeZones()
        .Select(tz => tz.Id).ToArray();

    protected override async Task OnInitializedAsync()
    {
        _deye = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.DeyeCloudOptions>("DeyeCloud");
        _tuya = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.TuyaOptions>("Tuya");
        _polling = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.PollingOptions>("Polling");
        _display = await SettingsService.LoadSectionAsync<DeyeSolar.Domain.Options.DisplayOptions>("Display");
        _selectedStationId = _deye.StationId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _display.TimeZoneId == "UTC")
        {
            try
            {
                var tz = await JS.InvokeAsync<string>("eval", "Intl.DateTimeFormat().resolvedOptions().timeZone");
                if (!string.IsNullOrEmpty(tz))
                {
                    _display.TimeZoneId = tz;
                    await SaveDisplay();
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    // -- DeyeCloud --
    private async Task SaveDeye()
    {
        await SettingsService.SaveSectionAsync("DeyeCloud", _deye);
        DeyeClient.InvalidateToken();
        Snackbar.Add("DeyeCloud settings saved", Severity.Success);
    }

    private async Task FetchStations()
    {
        _loadingStations = true; _errorMessage = null; _stations = null; _devices = null;
        try
        {
            await SaveDeye();
            _stations = await DeyeClient.GetStationsWithDevicesAsync(CancellationToken.None);
            if (_stations.Count == 1) _selectedStationId = _stations[0].Id;
        }
        catch (Exception ex) { _errorMessage = $"Failed: {ex.Message}"; }
        finally { _loadingStations = false; }
    }

    private async Task FetchDevices()
    {
        _loadingDevices = true; _errorMessage = null; _devices = null;
        try
        {
            _devices = await DeyeClient.GetDevicesForStationAsync(_selectedStationId, CancellationToken.None);
            var inverters = _devices.Where(d => d.DeviceType == "INVERTER").ToList();
            if (inverters.Count == 1) await SelectDevice(inverters[0]);
        }
        catch (Exception ex) { _errorMessage = $"Failed: {ex.Message}"; }
        finally { _loadingDevices = false; }
    }

    private async Task SelectDevice(DeyeSolar.Infrastructure.DeyeCloud.DeyeDevice device)
    {
        _deye.StationId = _selectedStationId;
        _deye.DeviceSn = device.SerialNumber;
        await SaveDeye();
        Snackbar.Add($"Selected: {device.DeviceType} SN {device.SerialNumber}", Severity.Info);
    }

    // -- Tuya --
    private async Task SaveTuya()
    {
        await SettingsService.SaveSectionAsync("Tuya", _tuya);
        TuyaClient.InvalidateToken();
        Snackbar.Add("Tuya settings saved", Severity.Success);
    }

    private async Task FetchTuyaDevices()
    {
        _loadingTuya = true; _errorMessage = null; _tuyaDevices = null;
        try
        {
            await SaveTuya();
            _tuyaDevices = await TuyaClient.GetDevicesAsync(CancellationToken.None);
            if (_tuyaDevices.Count == 1) await SelectTuyaDevice(_tuyaDevices[0]);
        }
        catch (Exception ex) { _errorMessage = $"Failed: {ex.Message}"; }
        finally { _loadingTuya = false; }
    }

    private async Task SelectTuyaDevice(DeyeSolar.Infrastructure.Tuya.TuyaDevice device)
    {
        _tuya.DeviceId = device.Id;
        await SaveTuya();
        Snackbar.Add($"Selected: {device.Name} ({device.Id})", Severity.Info);
    }

    private async Task TestOn()
    {
        try { await TuyaClient.TurnOnAsync(_tuya.DeviceId, CancellationToken.None); Snackbar.Add("ON", Severity.Success); }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task TestOff()
    {
        try { await TuyaClient.TurnOffAsync(_tuya.DeviceId, CancellationToken.None); Snackbar.Add("OFF", Severity.Success); }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    // -- Polling --
    private async Task SavePolling()
    {
        await SettingsService.SaveSectionAsync("Polling", _polling);
        Snackbar.Add("Polling settings saved", Severity.Success);
    }

    // -- Display --
    private async Task SaveDisplay()
    {
        await SettingsService.SaveSectionAsync("Display", _display);
        Snackbar.Add("Display settings saved", Severity.Success);
    }

    private Task<IEnumerable<string>> SearchTimezones(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_allTimeZones.AsEnumerable());
        return Task.FromResult(_allTimeZones
            .Where(tz => tz.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }
}
